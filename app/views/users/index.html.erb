<%= content_for(:title, "Users") %>

<h1>Users</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Location</th>
      <th>Time Zone</th>
      <th>Network Numbers</th>
      <th class="numeric">Total Network Numbers</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= link_to(user.name, user) %></td>
        <td><%= user.location %></td>
        <td><%= user.time_zone %></td>
        <td><%= user.network_ranges_s %></td>
        <td class="numeric"><%= user.total_network_numbers %></td>
      </tr>
    <% end %>
  </tbody>
</table>
