<h1><%= link_to(@user.name, @user) %></h1>

<% if @user.errors.any? %>
  <%= @user.errors.messages %>
<% end %>

<%= form_with(model: @user, url: @user, method: :patch) do |form| %>
  <div>
    <%= form.label(:email_address) %>
    <div><%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username"  %></div>
  </div>

  <div>
    <%= form.label(:name) %>
    <div><%= form.text_field :name, required: true, autofocus: true, autocomplete: "name", placeholder: "Display name/handle"  %></div>
  </div>

  <div>
    <%= form.label(:location) %>
    <div><%= form.text_field :location, required: false, autofocus: true, placeholder: "City and/or country" %></div>
  </div>

  <div>
    <%= form.label(:socials) %>
    <div><%= form.text_field :socials, required: false, autofocus: true, placeholder: "Mastodon, whatever" %></div>
  </div>

  <div>
    <%= form.label(:time_zone) %>
    <div><%= form.select :time_zone, @options.fetch(:time_zones), { selected: @user.time_zone }, {data: { controller: "time-zone", "time-zone-target" => "picker" } }%></div>
  </div>

  <div>
    <%= form.label(:network_ranges) %>
    <div data-controller="edit-network-number">
      <%= form.text_field(:network_ranges, value: @user.network_ranges_s, placeholder: "123, 400-402", required: true, data: { "edit-network-number-target" => "number" }) %>
      <% unless @user.network_ranges? %>
      <p class="helptext">
        Need inspiration? Network number
        <code style="font-weight: 500; cursor: pointer" data-action="click->edit-network-number#use" data-edit-network-number-target="freeNumber" title="Click to use!"><%= User.random_free_network_number %></code> is available!
        <br/>
      <% end %>
      <p class="helptext">
        Users aren't allowed to claim more than <%= User.max_allowed_network_count %> network numbers as there are only <%= AppleTalk.distinct_network_numbers %> to go around.
      </p>
    </div>
  </div>

  <div>
    <fieldset>
      <legend>Change password</legend>

      <div>
        <div><%= form.password_field :password, autocomplete: "new-password", placeholder: "New password", maxlength: 72 %></div>
      </div>

      <div>
        <div><%= form.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password", maxlength: 72 %></div>
      </div>
    </fieldset>
  </div>

  <div>
    <div><%= form.submit "Update" %></div>
  </div>
<% end %>
