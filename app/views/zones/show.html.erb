<%= content_for(:title, @zone.name) %>

<h1><%= @zone.name %></h1>

<div style="display: flex; gap: 10px">
<% [:edit].select { allowed_to?(:"#{it}?", @zone) }.each do |act| %>
  <div>
    <%= button_to(act.to_s.humanize, [act, @zone], method: :get) %>
  </div>
<% end %>
<%
  [:approve, :unapprove, :enable, :disable]
    .select { allowed_to?(:"#{it}?", @zone) }.each do |act| %>
  <div>
    <%= button_to(act.to_s.humanize, [act, @zone], method: :patch) %>
  </div>
<% end %>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr">
  <div>
    <h3>Details</h3>
    <dl style="display: grid; grid-template-columns: 1fr 2fr;">
      <dt>Owner</dt>
      <dd><%= @zone.user.name %></dd>

      <dt><%= Zone.human_attribute_name(:physical_layer) %></dt>
      <dd><%= Zone::PhysicalLayer.label_for(@zone.physical_layer) %></dd>

      <dt><%= Zone.human_attribute_name(:network_ranges) %></dt>
      <dd><code><%= @zone.network_ranges_s %></code></dd>

      <dt><%= Zone.human_attribute_name(:about) %></dt>
      <dd>
        <div style="border: solid 1px dimgray; padding: 0.5em">
          <%= render_markdown(@zone.about) %>
        </div>
      </dd>
      <dt><%= Zone.human_attribute_name(:static_endpoint) %></dt>
      <dd><code><%= @zone.static_endpoint %></code></dd>
    </dl>
  </div>
  <div>
    <h3>Status</h3>
    <dl style="display: grid; grid-template-columns: 1fr 2fr">
      <dt>Approved?</dt>
      <dd><%= @zone.approved? ? "Yes" : "No" %></dd>

      <dt>Enabled?</dt>
      <dd><%= @zone.enabled? ? "Yes" : "No" %></dd>

      <dt>Current public endpoint</dt>
      <dd><code><%= @zone.public_endpoint %></code></dd>
    </dl>
  </div>

  <div>
  </div>
</div>

<% if allowed_to?(:view_ddns_secrets?, @zone) %>
  <div>
    <h3>DDNS</h3>
    <p>
      This GlobalTalk Registry hosts a dynamic DNS service following the DynDNS2 protocol.
      Most any router will have DynDNS2 baked-in and give you the option to customise the update URL.
    </p>

    <dl style="display: grid; grid-template-columns: 1fr 2fr; row-gap: 5px;">
      <dt>Hostname</dt>
      <dd><code><%= @zone.ddns_fqdn %></code></dd>

      <dt>Update URL</dt>
      <dd><code><%= ddns_update_url %></code></dd>

      <dt>Username</dt>
      <dd>Ignored by us. Set to any value e.g. <code>ddns</code></dd>

      <dt>Password</dt>
      <dd><code><%= @zone.ddns_password %></code></dd>

      <dt>Last IP</dt>
      <dd><code><%= @zone.ddns_ip %></code></dd>
    </dl>

    <p>An example with cURL using your configuration:</p>
    <pre>curl -u ddns:<%= @zone.ddns_password %> '<%= ddns_update_url(myip: request.remote_ip, hostname: @zone.ddns_subdomain) %>'</pre>
  </div>
<% end %>
