<%= content_for(:title, "Zones") %>

<h1>Zones</h1>

<% if allowed_to?(:new?, Zone) %>
  <%= button_to("Register a Zone", new_zone_path, method: :get) %>
<% else %>
  <p class="private-alert" style="margin: 10px 0">Before registering your zone, please get your network and endpoint <%= link_to("set up", onboarding_path) %>.</p>
<% end %>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Owner</th>
      <th>Enabled?</th>
      <th>Published?</th>
    </tr>
  </thead>
  <tbody>
    <% @zones.each do |zone| %>
      <tr>
        <td><%= link_to(zone.name, zone) %></td>
        <td><%= zone.user.name %></td>
        <td><%= zone.enabled? %></td>
        <td><%= zone.exported? %></td>
      </tr>
    <% end %>
  </tbody>
</table>
