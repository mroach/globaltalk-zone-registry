
<div style="display: flex; justify-content: space-between;">
  <h1>Endpoint for <%= @endpoint.ranges_s %></h1>
  <div style="display: flex; gap: 6px">
    <% if allowed_to?(:edit?, @endpoint) %>
      <div>
        <%= button_to("Edit", [:edit, @endpoint], method: :get) %>
      </div>
    <% end %>
    <% if allowed_to?(:destroy?, @endpoint) %>
      <div>
        <%= button_to("Delete", @endpoint, method: :delete, data: { "turbo-confirm" => "Really delete this endpoint? This is irreversible."}) %>
      </div>
    <% end %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr;">

  <div>
    <h3>Owner</h3>
    <dl style="display: grid; grid-template-columns: 1fr 2fr; row-gap: 8px;">
      <dt>Name</dt>
      <dd><%= link_to(@endpoint.user.name, user_by_name_path(@endpoint.user.name)) %></dd>
    </dl>

    <h3>Addresses</h3>
    <dl style="display: grid; grid-template-columns: 1fr 2fr; row-gap: 8px">
      <dt><%= Endpoint.human_attribute_name(:static_endpoint) %></dt>
      <dd>
        <% unless @endpoint.static_endpoint.blank? %>
          <code><%= @endpoint.static_endpoint %></code>
        <% else %>
          <em>none</em>
        <% end %>
      </dd>

      <dt>Current public endpoint</dt>
      <dd>
        <% unless @endpoint.public_endpoint.blank? %>
          <code><%= @endpoint.public_endpoint %></code>
        <% else %>
          <em>none</em>
        <% end %>
        <p class="helptext">The <em>static endpoint</em> takes precedence over the DDNS hostname</p>
      </dd>
    </dl>
  </div>

  <div>
    <h3>Status</h3>
    <dl style="display: grid; grid-template-columns: 1fr 2fr; row-gap: 8px;">
      <dt>Enabled?</dt>
      <dd>
        <div style="display: flex; gap: 10px">
          <%= @endpoint.enabled? ? "Yes" : "No" %>
          <% if allowed_to?(:enable?, @endpoint) %>
            <%= button_to("Enable", [:enable, @endpoint], method: :patch) %>
          <% end %>
          <% if allowed_to?(:disable?, @endpoint) %>
            <%= button_to("Disable", [:disable, @endpoint], method: :patch) %>
          <% end %>
        </div>
        <p class="helptext">A disabled endpoint will be removed from the peer list.</p>
        </dd>
      </dd>

      <dt>Published?</dt>
      <dd>
        <div><%= @endpoint.exported? ? "Yes" : "No" %></div>
        <p class="helptext">To be published, an endpoint must enabled and have either a static address or an IP address set via dynamic DNS.</p>
      </dd>
    </dl>
  </div>
</div>

<% if @endpoint.notes.present? %>
  <h2>Notes</h2>
  <div style="border: solid dimgray 1px; padding: 1em">
    <%= render_markdown(@endpoint.notes) %>
  </div>
<% end %>

<% if allowed_to?(:view_ddns_secrets?, @endpoint) %>
  <div class="private-alert" style="margin-top: 20px">
    <h2>Dynamic DNS</h2>

    <div>
      <%=
        render_markdown(<<~MD)
          This GlobalTalk Registry hosts a dynamic DNS service following the DynDNS2 protocol.
          Most any router will have DynDNS2 support and give you the option to customise the update URL.

          ### Public IPv4

          In order for this to work, you have to have a publically routable IPv4 address.

          ### CGNAT

          This will not work if you're behind CGNAT and updates with CGNAT IPs will be rejected.
        MD
      %>
    </p>

    <h3>Your Secret DDNS Settings</h3>
    <dl style="width: 800px; margin: 20px; display: grid; grid-template-columns: 1fr 2fr; row-gap: 10px;">
      <dt>Update URL</dt>
      <dd><code><%= ddns_update_url %></code></dd>

      <dt>Hostname</dt>
      <dd><code><%= @endpoint.ddns_fqdn %></code></dd>

      <dt>Username</dt>
      <dd>Ignored by us. Set to any value e.g. <code>ddns</code></dd>

      <dt>Password</dt>
      <dd><code><%= @endpoint.ddns_password %></code></dd>

      <dt>Current IP</dt>
      <dd>
        <% if @endpoint.ddns_ip %>
          <code><%= @endpoint.ddns_ip %></code>
        <% else %>
          <em>No DDNS updates received yet.</em>
        <% end %>
      </dd>
    </dl>
  </div>
<% end %>
