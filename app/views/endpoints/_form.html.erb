<%= form_with(model: @endpoint) do |form| %>
  <div>
    <%= form.label(:ranges, "Network number or range(s)") %>
    <div data-controller="edit-network-number">
      <%= form.text_field(:ranges, placeholder: "123, 400-402", value: @endpoint.ranges_s, required: true, data: { "edit-network-number-target" => "number" }) %>
      <%= maybe_error_for(form.object, :ranges) %>
      <% unless @endpoint.ranges? %>
      <p class="helptext">
        Need inspiration? Network number
        <code style="font-weight: 500; cursor: pointer" data-action="click->edit-network-number#use" data-edit-network-number-target="freeNumber" title="Click to use!"><%= Endpoint.random_free_network_number %></code> is available!
        <br/>
      <% end %>
      <p class="helptext">
        Endpoints aren't allowed to claim more than <%= Endpoint.max_allowed_network_size %> network numbers as there are only <%= AppleTalk.distinct_network_numbers %> to go around.
      </p>
    </div>
  </div>

  <h2>Endpoint</h2>

  <div>
    <div>Reachability</div>
    <div>
      <%=
        render_markdown(<<~MD)
          Your AppleTalk router must be reachable by the public internet on UDP port 387.
          If you have a static IPv4 address or a hostname managed with dynamic DNS,
          enter that as the *Static Endpoint*.

          If you have a dynamic IP, you could enter it here, or leave this field blank
          and then after creating your endpoint you'll see information about using
          our dynamic DNS server which will get you set up with a hostname
          e.g. `my-name.#{DDNS.domain_name}`.
        MD
      %>
    </div>
    <%= form.label(:static_endpoint) %>
    <div>
      <%= form.text_field(:static_endpoint, placeholder: "Static IPv4 address or hostname", style: "width: 400px") %>
      <%= maybe_error_for(form.object, :static_endpoint) %>
    </div>
  </div>

  <div>
    <div>Notes</div>
    <div>
      <%= form.text_area(:notes, style: "width: 100%; height: 250px; font-family: monospace") %>
      <p class="helptext">Markdown is supported here.</p>
    </div>
  </div>

  <div>
    <div><%= form.submit "Update" %></div>
  </div>
<% end %>
