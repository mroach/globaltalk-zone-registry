root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4

[app/assets/builds/*]
end_of_line = unset
insert_final_newline = unset

[db/structure.sql]
indent_style = unset
indent_size = unset
